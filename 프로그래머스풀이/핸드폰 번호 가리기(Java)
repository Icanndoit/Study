class Solution {
    public String solution(String phone_number) {
        String answer = "";
        int j = 0;
        for (int i = phone_number.length() - 1; i >= 0; i--) {
            if (j >= 4)
                answer = "*" + answer;
            else
                answer = phone_number.charAt(i) + answer;
            j++;
        }
        return answer;
    }
}
