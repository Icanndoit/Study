#include<iostream>
using namespace std;

int dp[100001] = { 0 };
int main() {
	dp[1] = 1, dp[2] = 2;
	
	int n;
	cin >> n;
	for (int i = 1; i <= n; i++) {
		int num;  cin >> num;
		for (int j = 3; j <= num; j++) {
			int x = j;
			while (x > 0) {
				if (x % 10 == 0 || x % 10 == 1 || x % 10 == 2) {
					x /= 10;
					if (x == 0)
						dp[j] = dp[j - 1] + 1;
				}
				else {
					dp[j] = dp[j - 1];
					break;
				}
			}
		}
		cout << "Case #" << i << endl;
		cout << dp[num] % 1000000007 << endl;
	}

	return 0;
}
